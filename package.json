{
  "name": "hexdiff",
  "displayName": "HexDiff",
  "description": "View and compare binary files with HexDiff.",
  "version": "0.0.3",
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCustomEditor:hexdiff.hexEditor",
    "onCommand:hexdiff.compareSelected",
    "onCommand:hexdiff.compareWithGit"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "HexDiff",
      "properties": {
        "hexdiff.theme": {
          "type": "string",
          "enum": [
            "Auto",
            "Light",
            "Dark"
          ],
          "default": "Auto",
          "description": "Theme mode for differences highlighting. Auto inherits the IDE theme color."
        },
        "hexdiff.fontFamily": {
          "type": "string",
          "default": "'Courier New', monospace",
          "description": "Font family used in the HexDiff webview."
        }
      }
    },
    "customEditors": [
      {
        "viewType": "hexdiff.hexEditor",
        "displayName": "HexDiff",
        "selector": [
          {
            "filenamePattern": "*"
          }
        ],
        "priority": "option"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "hexdiff.compareSelected",
          "group": "compare",
          "when": "listMultiSelection"
        },
        {
          "command": "hexdiff.compareWithGit",
          "group": "compare@2",
          "when": "resourceScheme == file && !listMultiSelection"
        }
      ]
    },
    "commands": [
      {
        "command": "hexdiff.compareSelected",
        "title": "Compare Files (HexDiff)"
      },
      {
        "command": "hexdiff.compareWithGit",
        "title": "Compare with Git (HexDiff)"
      },
      {
        "command": "hexdiff.createBinaryFile",
        "title": "Create a new binary file (HexDiff)"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.17",
    "@types/vscode": "^1.70.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1"
  },
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Viriliter/vscode-hexdiff.git"
  },
  "publisher": "Viriliter"
}